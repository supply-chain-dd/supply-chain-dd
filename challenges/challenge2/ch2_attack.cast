[0.026942, "o", "\u001b[?1049h\u001b[45;1H\u001b[?1h\u001b=\r\u001b[38;2;131;148;150m─────┬─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[m\r\n     \u001b[38;2;131;148;150m│ \u001b[0mFile: \u001b[1m/home/skhoury/go/src/github.com/sherine-k/supply-chain-dd/challenges/challenge2/trivy-policies/copy_git_leak.rego\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m─────┼──────────────────────────────────────────────────────────────────"]
[0.000054, "o", "───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   1\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m METADATA\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   2\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m title: COPY copies .git directory into image layer\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   3\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m description: |\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   4\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m   Detects Dockerfiles that copy the entire build context (COPY . .) which\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   5\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94"]
[0.000113, "o", "m   includes the .git directory. Even if .git is deleted in a subsequent RUN\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   6\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m   layer, the data remains in the COPY layer and can be extracted by anyone\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   7\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m   with image pull access. Use a .dockerignore allowlist or multi-stage\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   8\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m   builds to prevent secrets in git history from leaking into images.\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m   9\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m schemas:\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  10\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m   - input: schema[\"dockerfile\"]\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  11\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m related_resources:\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  12\u001b[0m \u001b[38;2;131;1"]
