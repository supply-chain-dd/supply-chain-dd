[0.000102, "o", "BILITY STEP 1: Copy everything including .git directory\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  23\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m This creates a layer with .git content embedded\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  24\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;249;0;90mCOPY\u001b[0m\u001b[38;2;73;72;62m . .\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  25\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  26\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m Build the application\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  27\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;249;0;90mRUN \u001b[0m\u001b[38;2;73;72;62mCGO_ENABLED=0 GOOS=linux go build -o recipe-api main.go\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  28\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[m\r\n\u001b[38;2;131;148;150m  29\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m VULNERABILITY STEP 2: Attempting to remove .git directory\u001b[0m\u001b[m\r\n\u001b[38;2;131;148;150m  30\u001b[0m \u001b[38;2;131;148;150m│\u001b[0m \u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m SECURITY MISTAKE: This only creates a \"w"]
