[0.000306, "o", "\u001b[0m\r\n\u001b[4m\u001b[1m\u001b[4mDockerfile (dockerfile)\u001b[0m\u001b[4m\u001b[0m\r\n\r\n\u001b[0m\u001b[0mTests: 30 (SUCCESSES: 26, FAILURES: 4)\r\n\u001b[0m\u001b[0mFailures: 4 (UNKNOWN: 0, LOW: 1, MEDIUM: 0, HIGH: 1, CRITICAL: 2)\r\n\r\n\u001b[0m\u001b[0m \u001b[31m\u001b[1m(CRITICAL): \u001b[0m\u001b[0mCOPY copies entire build context (including .git) into image layer. Secrets in git history will persist in this layer even if deleted later. Use a .dockerignore allowlist or multi-stage build.\r\r\n\u001b[0m\u001b[0m\u001b[2m═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════\r\r\n\u001b[0m\u001b[0m\u001b[2mDetects Dockerfiles that copy the entire build context (COPY . .) which\r\nincludes the .git directory. Even if .git is deleted in a subsequent RUN\r\nlayer, the data remains in the COPY layer and can be extracted by anyone\r\nwith image pull access. Use a .dockerignore allowlist or multi-stage\r\nbuilds to prevent secrets in git history from leaking into images.\r\n\r\r\n\u001b[0m\u001b[0m\r\r\n\u001b[2mSee https://docs.docker.com/build/building/best-practices/#dockerignore\r\r\n\u001b[0m\u001b[0m\u001b[2m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\r\n\u001b[0m\u001b[0m \u001b[34mDockerfile\u001b[0m\u001b[2m:\u001b[0m\u001b[34m24\u001b[0m\r\r\n\u001b[0m\u001b[0m\u001b[2m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\r\n\u001b[0m\u001b[0m\u001b[31m  24 \u001b[0m\u001b[0m\u001b[31m[ \u001b[0m\u001b[0m\u001b[38;5;64mCOPY\u001b[0m . .\r\r\n\u001b[0m\u001b[0m\u001b[2m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\r\n\u001b[0m\u001b[0m\r\r\n\r\r\n\u001b[0m\u001b[0m \u001b[31m\u001b[1m(CRITICAL): \u001b[0m\u001b[0mRUN deletes .git but the data remains in the earlier COPY layer. Docker layers are immutable — 'rm -rf .git' only creates a whiteout marker in a new layer. Use .dockerignore to prevent .git from entering the build context.\r\r\n\u001b[0m\u001b[0m\u001b[2m════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════"]
[0.00005, "o", "═══════════════════════════════\r\r\n\u001b[0m\u001b[0m\u001b[2mDetects Dockerfiles that copy the entire build context (COPY . .) which\r\nincludes the .git directory. Even if .git is deleted in a subsequent RUN\r\nlayer, the data remains in the COPY layer and can be extracted by anyone\r\nwith image pull access. Use a .dockerignore allowlist or multi-stage\r\nbuilds to prevent secrets in git history from leaking into images.\r\n\r\r\n\u001b[0m\u001b[0m\r\r\n\u001b[2mSee https://docs.docker.com/build/building/best-practices/#dockerignore\r\r\n\u001b[0m\u001b[0m\u001b[2m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\r\n\u001b[0m\u001b[0m \u001b[34mDockerfile\u001b[0m\u001b[0m\u001b[2m:\u001b[0m\u001b[34m32\u001b[0m\u001b[34m-34\u001b[0m\r\r\n\u001b[0m\u001b[0m\u001b[2m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\r\n\u001b[0m\u001b[0m\u001b[31m  32 \u001b[0m\u001b[0m\u001b[31m┌ \u001b[0m\u001b[0m\u001b[38;5;64mRUN\u001b[0m rm -rf .git \u001b[38;5;245m&&\u001b[0m \u001b[38;5;124m\\\r\r\n\u001b[0m\u001b[0m\u001b[31m  33 \u001b[0m\u001b[0m\u001b[31m│ \u001b[0m\u001b[0m\u001b[0m    rm -rf .env* \u001b[38;5;245m&&\u001b[0m \u001b[38;5;124m\\\r\r\n\u001b[0m\u001b[0m\u001b[31m  34 \u001b[0m\u001b[0m\u001b[31m└ \u001b[0m\u001b[0m\u001b[0m    \u001b[38;5;33mecho\u001b[0m \u001b[38;5;37m\"Cleaned up sensitive files\"\u001b[0m\r\r\n\u001b[0m\u001b[0m\u001b[2m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\r\n\u001b[0m\u001b[0m\r\r\n\r\r\n\u001b[0m\u001b[0mAVD-DS-0002 \u001b[31m(HIGH): \u001b[0m\u001b[0mSpecify at least 1 USER command in Dockerfile with non-root user as argument\r\r\n\u001b[0m\u001b[0m\u001b[2m═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════\r\r\n\u001b[0m\u001b[0m\u001b[2mRunning containers with 'root' user can lead to a container escape situation. It is a best practice to run containers as non-root users, which can be done by adding a 'USER' statement to the Dockerfile.\r\r\n\u001b[0m\u001b[0m\r\r\n\u001b[2mSee https://avd.aquasec.com/misconfig/ds002\r\r\n\u001b[0m\u001b[0m\u001b[2m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────"]
[0.000017, "o", "──────────────────────────────────────────────────────────\r\r\n\u001b[0m\u001b[0m\r\r\n\r\r\n\u001b[0m\u001b[0mAVD-DS-0026 (LOW): \u001b[0m\u001b[0mAdd HEALTHCHECK instruction in your Dockerfile\r\r\n\u001b[0m\u001b[0m\u001b[2m═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════\r\r\n\u001b[0m\u001b[0m\u001b[2mYou should add HEALTHCHECK instruction in your docker container images to perform the health check on running containers.\r\r\n\u001b[0m\u001b[0m\r\r\n\u001b[2mSee https://avd.aquasec.com/misconfig/ds026\r\r\n\u001b[0m\u001b[0m\u001b[2m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\r\n\u001b[0m\u001b[0m\r\r\n\r\r\n\u001b[0m"]
