[0.000102, "o", "╭────┬──────────────────────────┬───────────────────────────────────────────╮\r\n│    │ Control name             │ Docs                                      │\r\n├────┼──────────────────────────┼───────────────────────────────────────────┤\r\n│ ✅ │ HostPath mount           │ https://kubescape.io/docs/controls/c-0048 │\r\n│ ✅ │ Workload with PVC access │ https://kubescape.io/docs/controls/c-0257 │\r\n│ ✅ │ Writable hostPath mount  │ https://kubescape.io/docs/controls/c-0045 │\r\n╰────┴──────────────────────────┴───────────────────────────────────────────╯\r\n"]
