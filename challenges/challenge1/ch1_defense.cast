[0.00013, "o", "\u001b[92m\u001b[92;1m[clone-pr-code : clone] \u001b[0mIf you want to create a new branch to retain commits you create, you may\r\n\u001b[92m\u001b[92;1m[clone-pr-code : clone] \u001b[0mdo so (now or later) by using -c with the switch command. Example:\r\n\u001b[92m\u001b[92;1m[clone-pr-code : clone] \u001b[0m\r\n\u001b[92m\u001b[92;1m[clone-pr-code : clone] \u001b[0m  git switch -c <new-branch-name>\r\n\u001b[92m\u001b[92;1m[clone-pr-code : clone] \u001b[0m\r\n"]
[0.000043, "o", "\u001b[92m\u001b[92;1m[clone-pr-code : clone] \u001b[0mOr undo this operation with:\r\n\u001b[92m\u001b[92;1m[clone-pr-code : clone] \u001b[0m\r\n"]
