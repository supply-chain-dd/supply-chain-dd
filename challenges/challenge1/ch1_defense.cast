[0.006302, "o", "\r\n\u001b[97m\u001b[1m1265 vulnerabilities found\u001b[22m\u001b[39m\u001b[38;5;238m\u001b[1m\u001b[22m\u001b[39m\r\n\u001b[38;5;238m\u001b[1m──────────────────────────\u001b[22m\u001b[39m\r\n\u001b[38;5;238m\u001b[1m\u001b[22m\u001b[39m\r\n\u001b[38;5;238m\u001b[1m\u001b[22m\u001b[39m\u001b[37mImages: alpine:3.18, golang:1.25\u001b[39m\r\n\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m\u001b[38;5;238m\u001b[1m* \u001b[22m\u001b[39m\u001b[37m28 \u001b[38;5;1m\u001b[1mCritical\u001b[22m\u001b[39m \u001b[39m\r\n\u001b[37m\u001b[39m\u001b[38;5;238m\u001b[1m* \u001b[22m\u001b[39m\u001b[37m153 \u001b[38;5;196m\u001b[1mHigh\u001b[22m\u001b[39m \u001b[39m\r\n\u001b[37m\u001b[39m\u001b[38;5;238m\u001b[1m* \u001b[22m\u001b[39m\u001b[37m294 \u001b[38;5;166m\u001b[1mMedium\u001b[22m\u001b[39m \u001b[39m\r\n\u001b[37m\u001b[39m\u001b[38;5;238m\u001b[1m* \u001b[22m\u001b[39m\u001b[37m790 \u001b[38;5;7m\u001b[1mOther\u001b[22m\u001b[39m \u001b[39m\r\n\u001b[37m\u001b[39m\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m"]
[0.000032, "o", "\u001b[37mReceive a full report for alpine by running: \u001b[97m\u001b[1m'$ kubescape scan image alpine:3.18'\u001b[22m\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m\u001b[37mReceive a full report for golang by running: \u001b[97m\u001b[1m'$ kubescape scan image golang:1.25'\u001b[22m\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m"]
