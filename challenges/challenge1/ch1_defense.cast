[0.008806, "o", "\r\n\u001b[97m\u001b[1mWorkload security posture overview for:\u001b[22m\u001b[39m\r\n\u001b[97m\u001b[1m\u001b[22m\u001b[39m"]
[0.000083, "o", "+-----------+-----------------------------------------------+\r\n| Namespace | \u001b[97m\u001b[1mci\u001b[22m\u001b[39m                                            |\r\n|      Kind | \u001b[97m\u001b[1mPod\u001b[22m\u001b[39m                                           |\r\n|      Name | \u001b[97m\u001b[1mpr-quality-check-c72cf-run-quality-checks-pod\u001b[22m\u001b[39m |\r\n+-----------+-----------------------------------------------+\r\n"]
[0.000031, "o", "\u001b[37m\u001b[39m\r\n\u001b[37mIn this overview, Kubescape shows you a summary of the security posture of a workload, including key controls that apply to its configuration, and the vulnerability status of the container image.\u001b[39m\r\n\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m"]
[0.000098, "o", "\u001b[97m\u001b[1mSupply chain\u001b[22m\u001b[39m\r\n\u001b[97m\u001b[1m\u001b[22m\u001b[39m"]
[0.000069, "o", "╭────┬──────────────────────────────┬───────────────────────────────────────────╮\r\n│    │ Control name                 │ Docs                                      │\r\n├────┼──────────────────────────────┼───────────────────────────────────────────┤\r\n│ ⚠️ │ Images from allowed registry │ https://kubescape.io/docs/controls/c-0078 │\r\n╰────┴──────────────────────────────┴───────────────────────────────────────────╯\r\n"]
[0.000028, "o", "\u001b[97m\u001b[1m* Control configurations are empty (docs: https://kubescape.io/docs/frameworks-and-controls/configuring-controls)\u001b[22m\u001b[39m\r\n\u001b[97m\u001b[1m\u001b[22m\u001b[39m\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m"]
[0.000019, "o", "\u001b[97m\u001b[1mResource management\u001b[22m\u001b[39m\r\n\u001b[97m\u001b[1m\u001b[22m\u001b[39m"]
[0.000075, "o", "╭────┬──────────────────────────────┬───────────────────────────────────────────╮\r\n│    │ Control name                 │ Docs                                      │\r\n├────┼──────────────────────────────┼───────────────────────────────────────────┤\r\n│ ❌ │ Ensure CPU limits are set    │ https://kubescape.io/docs/controls/c-0270 │\r\n│ ❌ │ Ensure memory limits are set │ https://kubescape.io/docs/controls/c-0271 │\r\n╰────┴──────────────────────────────┴───────────────────────────────────────────╯\r\n"]
[0.000004, "o", "\u001b[37m\u001b[39m\r\n\u001b[37m\u001b[39m"]
